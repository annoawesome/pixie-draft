{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "typescript",
      "tsconfig": "tsconfig.json",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent"
      },
      "group": "build",
      "label": "tsc: build"
    },
    {
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/src/public/"
      },
      "presentation": {
        "reveal": "silent"
      },
      "command": "npx vite build --emptyOutDir --minify false --mode development ",
      "group": "build",
      "label": "vite: build dev"
    },
    {
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/src/public/"
      },
      "presentation": {
        "reveal": "silent"
      },
      "command": "npx vite build --emptyOutDir ",
      "group": "build",
      "label": "vite: build prod"
    },
    {
      "dependsOn": ["tsc: build", "vite: build dev"],
      "group": "build",
      "label": "Build App"
    },
    {
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/src/public/"
      },
      "presentation": {
        "reveal": "silent"
      },
      "command": "npx vite --host",
      "group": "build",
      "label": "vite: dev"
    },
    {
      "type": "npm",
      "script": "test:run",
      "group": "test",
      "label": "npm: run test",
      "detail": "Run every single test visible to Vitest"
    }
  ]
}
